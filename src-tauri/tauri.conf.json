{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TyeGit",
  "version": "2.2.4",
  "identifier": "com.vesper.tyegit",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TyeGit",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://akshaypatel.me/tyegit/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxOTU2OEYxRTY5MzQyOEMKUldTTVFwUG04V2lWa1VFU1ZDYklGUW1iOUdya2ZmaTlJcGpKRTljR3B6VFdqa29MZnVjbEtlZmkK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
